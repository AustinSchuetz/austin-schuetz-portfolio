Options -Indexes

RewriteEngine On

# AutoSSL domain-control validation must never be rewritten or blocked
RewriteRule ^\.well-known/ - [L]

# Protected application directories (each also ships its own deny .htaccess)
RewriteRule ^(app|content|storage|templates|scripts|tests|design)(/|$) - [F]

# The retired WordPress install stays on disk (owner's choice) — deny all web
# access to it. Anchored to the root, so client sites in subfolders (which run
# their own RewriteEngine) are unaffected.
RewriteRule ^(wp-admin|wp-content|wp-includes)(/|$) - [F]
RewriteRule ^(wp-[a-z-]+\.php|xmlrpc\.php|license\.txt|readme\.html)$ - [F]

# Dotfiles and sensitive file types — ROOT-ANCHORED so nothing here can ever
# apply to the client-site subfolders sharing this docroot. Deeper protection
# for our own dirs comes from their per-directory deny .htaccess files.
RewriteRule ^\.(git|env)(/|$) - [F]
RewriteRule ^[^/]+\.(json|md|yml|lock)$ - [F]

# Force-HTTPS + www -> apex (cert live via acme.sh since 2026-07-06)
RewriteCond %{HTTPS} !=on [OR]
RewriteCond %{HTTP_HOST} ^www\. [NC]
RewriteRule ^ https://austinschuetz.com%{REQUEST_URI} [R=301,L]

# Front controller
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.php [L]

# NOTE: no ExpiresByType here on purpose — Expires directives INHERIT into the
# client-site subfolders sharing this docroot. Cache headers live in
# assets/.htaccess and media/.htaccess instead, scoped to our own files only.
